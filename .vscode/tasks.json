{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build Project",
      "type": "shell",
      "command": "gcc",
      "args": [
        "src/main.c",
        "src/display/digit.c",
        "src/display/segment.c",
        "src/clock/clock.c",
        "src/display/display.c",
        "-o", "main",
        "-IC:/raylib/src",
        "-LC:/raylib/src",
        "-lraylib",
        "-lopengl32",
        "-lgdi32",
        "-lwinmm",
        "-Wall",
        "-Wextra"
      ],
      "group": "build"
    }
  ]
}